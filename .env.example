# === BINANCE ===
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_TESTNET=true

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === BOT CONFIG ===
SYMBOL=BTC/USDT
TIMEFRAME=5m
QUOTE_SIZE=50
MAX_POSITIONS=1
RISK_PER_TRADE=0.02
STRATEGY=scalper

# === SCALPER ===
HIGHER_TF=15m
SCALPER_VOL_MULT=1.5
SCALPER_MAX_EMA_DIST_PCT=0.8
SCALPER_LOOKBACK_BARS=12
SCALPER_TP_RR=1.5

# === COOLDOWN ===
COOLDOWN_LOSSES=2
COOLDOWN_MINUTES=30
DAILY_LOSS_LIMIT=3

# === COPY TRADE (Solana) ===
SOLANA_PRIVATE_KEY=your_base58_private_key_here
SOLANA_RPC_URL=https://solana-rpc.publicnode.com

# === COPY TRADE (Binance) ===
COPY_TRADE_POSITION_SIZE_USD=50
COPY_TRADE_MAX_POSITIONS=3
COPY_TRADE_MIN_CONFIDENCE=0.60
COPY_TRADE_SOL_SIZE_SOL=0.05
COPY_TRADE_SLIPPAGE_BPS=200

# === BOT ===
CHECK_INTERVAL_MINUTES=5
LOG_LEVEL=INFO
